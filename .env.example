# ============================================================
# ElectionIQ – Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# --- Google Cloud Project ---
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# --- Vertex AI / Gemini ---
VERTEX_AI_LOCATION=us-central1
GEMINI_MODEL=gemini-1.5-pro

# --- Google Maps (Frontend) ---
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- Google Calendar (Frontend OAuth) ---
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id
VITE_GOOGLE_CALENDAR_API_KEY=your-google-calendar-api-key

# --- Firebase / Firestore ---
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-gcp-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# --- Backend Service Account ---
# Path to your Google Cloud service account JSON key (for local dev only)
# In Cloud Run, use Workload Identity Federation instead
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# --- Backend Server ---
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Frontend Dev Server ---
VITE_API_BASE_URL=http://localhost:5000
